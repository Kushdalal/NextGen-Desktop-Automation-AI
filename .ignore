# ==============================================================================
# JARVIS Flask Project - Search & Indexing Ignore File (.ignore)
# ==============================================================================
# This file is used by tools like ripgrep (rg), fd, silver searcher (ag), and VS Code
# to ignore files and directories from global searches and file indexers.
# Format is identical to .gitignore.
# ==============================================================================

# Python bytecode and caches
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.benchmarks/

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Application databases
*.db
*.sqlite
*.sqlite3
chat_memory.db

# Dynamic upload and index directories
uploads/
faiss_indexes/
static/

# Dynamic text summaries generated by the AI agent
summary_*.txt
summary_agent_*.txt
summary_and___about_ai_agent_*.txt

# Logs and temporary files
*.log
*.tmp
*.temp

# IDEs, Editors, and OS-specific files
.vscode/
.idea/
.gemini/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db
