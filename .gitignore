# ==============================================================================
# JARVIS Flask Project - Git Ignore File (.gitignore)
# ==============================================================================
# This file prevents large, temporary, or sensitive files from being tracked by Git.
# ==============================================================================

# Python bytecode and caches
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.benchmarks/

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Application databases (contains dynamic user chats & reminders)
*.db
*.sqlite
*.sqlite3
chat_memory.db

# Dynamic upload and index directories (keeps runtime files out of git)
uploads/
faiss_indexes/

# Dynamic text summaries generated by the AI agent
summary_*.txt
summary_agent_*.txt
summary_and___about_ai_agent_*.txt

# Logs and temporary files
*.log
*.tmp
*.temp

# IDEs, Editors, and OS-specific files
.vscode/
.idea/
.gemini/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# Sensitive credentials
.env
